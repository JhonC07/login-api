{
  "info": {
    "_postman_id": "f4e4983b-6bbd-4d5e-b662-bfa6539d78a0",
    "name": "login-api",
    "description": "Coleccion de pruebas para la API academica de registro y autenticacion.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Registro exitoso",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{testUsername}}\",\n  \"password\": \"{{testPassword}}\"\n}"
        },
        "url": "{{baseUrl}}{{registerPath}}",
        "description": "Registra un usuario nuevo en memoria."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('El registro responde 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('El registro exitoso retorna el mensaje esperado', function () {",
              "    pm.expect(pm.response.text()).to.eql('Usuario registrado correctamente');",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "2. Usuario duplicado",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{testUsername}}\",\n  \"password\": \"{{testPassword}}\"\n}"
        },
        "url": "{{baseUrl}}{{registerPath}}",
        "description": "Intenta registrar nuevamente el mismo usuario. Ejecutar despues de 'Registro exitoso'."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('El usuario duplicado responde 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('El registro duplicado retorna el mensaje esperado', function () {",
              "    pm.expect(pm.response.text()).to.eql('El usuario ya existe');",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "3. Login exitoso",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{testUsername}}\",\n  \"password\": \"{{testPassword}}\"\n}"
        },
        "url": "{{baseUrl}}{{loginPath}}",
        "description": "Autentica un usuario previamente registrado."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('El login responde 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('El login exitoso retorna el mensaje esperado', function () {",
              "    pm.expect(pm.response.text()).to.eql('Autenticacion satisfactoria');",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "4. Login incorrecto",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{testUsername}}\",\n  \"password\": \"{{wrongPassword}}\"\n}"
        },
        "url": "{{baseUrl}}{{loginPath}}",
        "description": "Intenta autenticar al usuario con una contrasena incorrecta."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('El login incorrecto responde 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('El login incorrecto retorna el mensaje esperado', function () {",
              "    pm.expect(pm.response.text()).to.eql('Error en la autenticacion');",
              "});"
            ]
          }
        }
      ],
      "response": []
    }
  ]
}
